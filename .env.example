# AuraPredict — environment variables
# Copy this file to .env.local and fill in your values.

# V5 contract address (deployed on Arc Testnet)
VITE_PREDICTION_MARKET_ADDRESS=0x

# V5 deployment block (used for event log scanning)
VITE_AURAPREDICT_V5_DEPLOYMENT_BLOCK=0

# WalletConnect project ID — get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Circle AppKit API key — https://developers.circle.com
VITE_CIRCLE_APP_KIT_KEY=

# Indexer base URL (defaults to http://127.0.0.1:8787 in dev, https://api.aurapredict.xyz in prod)
VITE_AURA_INDEXER_URL=

# Arc Testnet RPC URL override (optional — uses public endpoints by default)
VITE_ARC_RPC_URL=
