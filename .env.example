# AuraPredict — environment variables
# Copy this file to .env.local and fill in your values.

# V5 contract address (deployed on Arc Testnet)
VITE_PREDICTION_MARKET_ADDRESS=0x

# V5 deployment block (used for event log scanning)
VITE_AURAPREDICT_V5_DEPLOYMENT_BLOCK=0

# WalletConnect project ID — get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Circle AppKit API key — https://developers.circle.com
VITE_CIRCLE_APP_KIT_KEY=

# Indexer base URL (defaults to http://127.0.0.1:8787 in dev, https://api.auraon.xyz in prod)
VITE_AURA_INDEXER_URL=

# Arc Testnet RPC URL override (optional — uses public endpoints by default)
VITE_ARC_RPC_URL=
VITE_ARC_RPC_URLS=
VITE_ARC_WS_URLS=

# Indexer: event-first on Arc deterministic finality. Full state audit defaults
# to every 6 hours; set it to 0 to disable after cached state recovery.
AURA_INDEXER_RPC_URLS=
AURA_INDEXER_EVENT_RPC_URLS=
AURA_INDEXER_CONTRACT_REFRESH_MS=21600000

# Recommended keeper signer: Circle Developer-Controlled Wallet.
# These are server-only secrets; never prefix them with VITE_.
AURA_RESOLVER_SIGNER_MODE=circle-api
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
AURA_CIRCLE_DEV_WALLET_ID=
AURA_CIRCLE_DEV_WALLET_ADDRESS=
AURA_CIRCLE_DEV_BLOCKCHAIN=ARC-TESTNET
AURA_CIRCLE_DEV_FEE_LEVEL=MEDIUM
AURA_CIRCLE_DEV_POLL_MS=2000
AURA_CIRCLE_DEV_TIMEOUT_MS=180000
