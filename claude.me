```
src/
  App.tsx                  # main app (~12k lines — ongoing extraction)
  types.ts                 # all shared TypeScript types
  constants.ts             # all shared constants
  contracts/               # ABIs
  lib/
    format.ts              # USDC formatting, address formatting
    marketUtils.ts         # market display helpers
