{
  "name": "aurapredict",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint src",
    "indexer": "node indexer/server.mjs",
    "indexer:once": "node indexer/server.mjs --once",
    "indexer:export-static": "node indexer/export-static.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "compile": "hardhat compile",
    "abi:v5": "node scripts/export_v5_abi.mjs",
    "test": "hardhat test",
    "test:e2e": "playwright test",
    "oracle:backtest": "node scripts/oracle_backtest.mjs",
    "smoke:api": "node scripts/check_production_api.mjs",
    "smoke:resolution": "node scripts/check_resolution_run_api.mjs",
    "oracle:regression": "node scripts/oracle_regression_check.mjs",
    "deploy:arc": "hardhat run scripts/deploy.js --network arcTestnet",
    "deploy:arc:v5": "set AURA_CONTRACT_VERSION=V5&& hardhat run scripts/deploy.js --network arcTestnet",
    "seed:markets": "hardhat run scripts/seed_markets.js --network arcTestnet",
    "seed:markets:dry": "set DRY_RUN=1&& hardhat run scripts/seed_markets.js --network arcTestnet"
  },
  "dependencies": {
    "@circle-fin/adapter-viem-v2": "^1.11.2",
    "@circle-fin/app-kit": "^1.7.0",
    "@circle-fin/user-controlled-wallets": "^10.6.0",
    "@circle-fin/w3s-pw-web-sdk": "^1.1.11",
    "@lifi/sdk": "^3.16.3",
    "@reown/appkit": "^1.8.21",
    "@reown/appkit-adapter-ethers": "^1.8.21",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "buffer": "^6.0.3",
    "dotenv": "^16.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.23.7"
  },
  "overrides": {
    "ws": "8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "ethers": "^6.17.0",
    "globals": "^17.6.0",
    "hardhat": "^2.22.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.11"
  }
}
